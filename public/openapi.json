{
  "openapi": "3.1.0",
  "info": {
    "title": "Tokenization Service API",
    "version": "1.0.0",
    "description": "REST API for the Tokenization Service — a platform for submitting, evaluating, and tokenizing real-world assets (RWA) on the Bitcoin Liquid Network.\n\n## Authentication\nAll protected endpoints require a Bearer JWT token obtained from the Auth service.\n\n## Asset Lifecycle\n1. **Submit** an asset with metadata and supporting documents.\n2. **Evaluate** the asset via AI-powered analysis.\n3. **Tokenize** approved assets into tradable Liquid Network tokens.",
    "contact": {
      "name": "Tokenization Ecosystem Team",
      "email": "api@tokenization-ecosystem.com",
      "url": "https://docs.tokenization-ecosystem.com"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://tokenization-ecosystem.com/terms"
    }
  },
  "servers": [
    {
      "url": "https://api.tokenization-ecosystem.com",
      "description": "Production"
    },
    {
      "url": "https://staging-api.tokenization-ecosystem.com",
      "description": "Staging"
    },
    {
      "url": "http://localhost:8000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Observability",
      "description": "Health checks, readiness probes, and Prometheus metrics"
    },
    {
      "name": "Assets",
      "description": "Submit, query, and manage real-world asset records"
    },
    {
      "name": "Evaluation",
      "description": "Request AI-powered asset evaluation and scoring"
    },
    {
      "name": "Tokenization",
      "description": "Convert approved assets into Liquid Network tokens"
    },
    {
      "name": "Documents",
      "description": "Upload and download asset supporting documents"
    }
  ],
  "paths": {
