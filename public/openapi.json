              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssetCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "title": "Description"
          },
          "category": {
            "type": "string",
            "enum": [
              "real_estate",
              "commodity",
              "invoice",
              "art",
              "other"
            ],
            "title": "Category"
          },
          "valuation_sat": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Valuation Sat"
          },
          "documents_url": {
            "type": "string",
            "minLength": 1,
            "format": "uri",
            "title": "Documents Url"
          }
        },
        "type": "object",
        "required": [
          "name",
          "description",
          "category",
          "valuation_sat",
          "documents_url"
        ],
        "title": "AssetCreateRequest"
      },
      "AssetDetailOut": {
