          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "category": {
            "type": "string",
            "enum": [
              "real_estate",
              "commodity",
              "invoice",
              "art",
              "other"
            ],
            "title": "Category"
          },
          "valuation_sat": {
            "type": "integer",
            "title": "Valuation Sat"
          },
          "documents_url": {
