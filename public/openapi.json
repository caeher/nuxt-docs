        }
      }
    },
    "/liquid/info": {
      "get": {
        "tags": ["Observability"],
        "summary": "Liquid Network Info",
        "description": "Returns current Liquid Network node information including block height, network type, and connectivity status.",
        "operationId": "liquid_info_liquid_info_get",
        "responses": {
          "200": {
            "description": "Liquid Network node information",
            "content": {
              "application/json": {
