                }
              }
            }
          }
        }
      }
    },
    "/assets/{asset_id}": {
      "get": {
        "tags": ["Assets"],
        "summary": "Get asset details",
        "description": "Returns full asset information including AI evaluation results (score, analysis, projected ROI) and tokenization details (Liquid asset ID, supply, pricing).",
        "operationId": "get_asset_assets__asset_id__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "asset_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Asset Id"
            }
          },
          {
            "name": "X-API-Key",
            "in": "header",
