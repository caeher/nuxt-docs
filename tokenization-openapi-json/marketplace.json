  "components": {
    "schemas": {
      "CancelOrderResponse": {
        "properties": {
          "order": {
            "$ref": "#/components/schemas/CancelledOrderOut"
          }
        },
        "type": "object",
        "required": [
          "order"
        ],
        "title": "CancelOrderResponse"
      },
      "CancelledOrderOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "status": {
            "type": "string",
            "const": "cancelled",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "title": "CancelledOrderOut"
      },
      "DisputeOpenRequest": {
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 1,
            "title": "Reason"
          }
        },
        "type": "object",
        "required": [
          "reason"
        ],
        "title": "DisputeOpenRequest"
      },
      "DisputeOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "trade_id": {
            "type": "string",
            "format": "uuid",
            "title": "Trade Id"
          },
          "opened_by": {
            "type": "string",
            "format": "uuid",
            "title": "Opened By"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "resolved"
            ],
            "title": "Status"
          },
          "resolution": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "refund",
                  "release"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolution"
          },
          "resolved_by": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolved By"
          },
          "resolved_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resolved At"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "trade_id",
          "opened_by",
          "reason",
          "status",
          "created_at"
        ],
        "title": "DisputeOut"
      },
      "DisputeResolveRequest": {
        "properties": {
          "resolution": {
            "type": "string",
            "enum": [
              "refund",
              "release"
            ],
            "title": "Resolution"
          },
          "pset": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Pset"
          }
        },
        "type": "object",
        "required": [
          "resolution"
        ],
        "title": "DisputeResolveRequest"
      },
      "DisputeResponse": {
        "properties": {
          "dispute": {
            "$ref": "#/components/schemas/DisputeOut"
          }
        },
        "type": "object",
        "required": [
          "dispute"
        ],
        "title": "DisputeResponse"
      },
      "EscrowOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "trade_id": {
            "type": "string",
            "format": "uuid",
            "title": "Trade Id"
          },
          "multisig_address": {
            "type": "string",
            "title": "Multisig Address"
          },
          "locked_amount_sat": {
            "type": "integer",
            "title": "Locked Amount Sat"
          },
          "funding_txid": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Funding Txid"
          },
          "release_txid": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Release Txid"
          },
          "refund_txid": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Refund Txid"
          },
          "status": {
            "type": "string",
            "enum": [
              "created",
              "funded",
              "inspection_pending",
              "released",
              "refunded",
              "disputed",
              "expired"
            ],
            "title": "Status"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "title": "Expires At"
          },
          "multisig_mode": {
            "type": "string",
            "enum": [
              "standard",
              "external_api"
            ],
            "title": "Multisig Mode",
            "default": "standard"
          },
          "settlement_metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Settlement Metadata"
          }
        },
        "type": "object",
        "required": [
          "id",
          "trade_id",
          "multisig_address",
          "locked_amount_sat",
          "status",
          "expires_at"
        ],
        "title": "EscrowOut"
      },
      "EscrowResponse": {
        "properties": {
          "escrow": {
            "$ref": "#/components/schemas/EscrowOut"
          }
        },
        "type": "object",
        "required": [
          "escrow"
        ],
        "title": "EscrowResponse"
      },
      "EscrowSignRequest": {
        "properties": {
          "pset": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Pset"
          }
        },
        "type": "object",
        "title": "EscrowSignRequest"
      },
      "ExternalEscrowSignRequest": {
        "properties": {
          "pset": {
            "anyOf": [
              {
