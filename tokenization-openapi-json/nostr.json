  "components": {
    "schemas": {
      "AnnouncementPublishRequest": {
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 140,
            "minLength": 1,
            "title": "Title"
          },
          "content": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "Content"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 280
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          },
          "identifier": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ],
            "title": "Identifier"
          },
          "hashtags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 12,
            "title": "Hashtags"
          },
          "location": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ],
            "title": "Location"
          },
          "price_amount": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*(?:\\d{0,10}|(?=[\\d.]{1,19}0*$)\\d{0,10}\\.\\d{0,8}0*$)"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Amount"
          },
          "price_currency": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 8,
                "minLength": 3
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Currency"
          },
          "price_frequency": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 32
              },
              {
                "type": "null"
              }
            ],
            "title": "Price Frequency"
          },
          "reference_url": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "format": "uri"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reference Url"
          },
          "image_urls": {
            "items": {
              "type": "string",
              "minLength": 1,
              "format": "uri"
            },
            "type": "array",
            "maxItems": 6,
            "title": "Image Urls"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "sold"
            ],
            "title": "Status",
            "default": "active"
          }
        },
        "type": "object",
        "required": [
          "title",
          "content"
        ],
        "title": "AnnouncementPublishRequest"
      },
      "AnnouncementPublishResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kind": {
            "type": "integer",
            "const": 30402,
            "title": "Kind"
          },
          "pubkey": {
            "type": "string",
            "title": "Pubkey"
          },
          "identifier": {
            "type": "string",
            "title": "Identifier"
          },
          "accepted_relays": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Accepted Relays"
          },
          "failed_relays": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Failed Relays"
          }
        },
        "type": "object",
        "required": [
          "id",
          "kind",
          "pubkey",
          "identifier",
          "accepted_relays",
          "failed_relays"
        ],
        "title": "AnnouncementPublishResponse"
      },
      "CampaignCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 140,
            "minLength": 1,
            "title": "Name"
          },
          "funding_mode": {
            "type": "string",
            "enum": [
              "intraledger",
              "external"
            ],
            "title": "Funding Mode"
          },
          "reward_amount_sat": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Reward Amount Sat"
          },
          "budget_total_sat": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Budget Total Sat"
          },
          "max_rewards_per_user": {
            "type": "integer",
            "maximum": 1000.0,
            "minimum": 1.0,
            "title": "Max Rewards Per User",
            "default": 1
          },
          "start_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start At"
          },
          "end_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "End At"
          },
          "triggers": {
            "items": {
              "$ref": "#/components/schemas/CampaignTriggerIn"
            },
            "type": "array",
            "maxItems": 20,
            "minItems": 1,
            "title": "Triggers"
          }
        },
        "type": "object",
        "required": [
          "name",
          "funding_mode",
          "reward_amount_sat",
          "budget_total_sat",
          "triggers"
        ],
        "title": "CampaignCreateRequest"
      },
      "CampaignFundingOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "funding_mode": {
            "type": "string",
            "enum": [
              "intraledger",
              "external"
            ],
            "title": "Funding Mode"
          },
          "amount_sat": {
            "type": "integer",
            "title": "Amount Sat"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "cancelled",
              "refunded"
            ],
            "title": "Status"
          },
          "payment_hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payment Hash"
          },
          "payment_request": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payment Request"
          },
          "confirmed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confirmed At"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "funding_mode",
          "amount_sat",
          "status"
        ],
        "title": "CampaignFundingOut"
      },
      "CampaignFundingRequest": {
        "properties": {
          "amount_sat": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Amount Sat"
          }
        },
        "type": "object",
        "required": [
          "amount_sat"
        ],
        "title": "CampaignFundingRequest"
      },
      "CampaignMatchOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "relay_url": {
            "type": "string",
            "title": "Relay Url"
          },
          "event_id": {
            "type": "string",
            "title": "Event Id"
          },
          "event_pubkey": {
            "type": "string",
            "title": "Event Pubkey"
          },
          "event_kind": {
            "type": "integer",
            "title": "Event Kind"
          },
          "match_fingerprint": {
            "type": "string",
            "title": "Match Fingerprint"
          },
          "status": {
            "type": "string",
            "enum": [
              "matched",
              "ignored",
              "reserved",
              "paid",
              "failed"
            ],
            "title": "Status"
          },
          "ignore_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ignore Reason"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "relay_url",
          "event_id",
          "event_pubkey",
          "event_kind",
          "match_fingerprint",
          "status",
          "created_at"
        ],
        "title": "CampaignMatchOut"
      },
      "CampaignOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "funding_pending",
              "active",
              "paused",
              "completed",
              "exhausted",
              "cancelled",
              "failed"
            ],
            "title": "Status"
          },
          "funding_mode": {
            "type": "string",
            "enum": [
              "intraledger",
              "external"
            ],
            "title": "Funding Mode"
          },
          "reward_amount_sat": {
            "type": "integer",
            "title": "Reward Amount Sat"
          },
          "budget_total_sat": {
            "type": "integer",
            "title": "Budget Total Sat"
          },
          "budget_reserved_sat": {
            "type": "integer",
            "title": "Budget Reserved Sat"
          },
          "budget_spent_sat": {
            "type": "integer",
            "title": "Budget Spent Sat"
          },
          "budget_refunded_sat": {
            "type": "integer",
            "title": "Budget Refunded Sat"
          },
          "max_rewards_per_user": {
            "type": "integer",
            "title": "Max Rewards Per User"
          },
          "start_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start At"
          },
          "end_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "End At"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "triggers": {
            "items": {
              "$ref": "#/components/schemas/CampaignTriggerOut"
            },
            "type": "array",
            "title": "Triggers"
          },
          "fundings": {
            "items": {
              "$ref": "#/components/schemas/CampaignFundingOut"
            },
            "type": "array",
            "title": "Fundings"
          }
        },
        "type": "object",
